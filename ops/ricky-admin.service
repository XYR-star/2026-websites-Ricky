[Unit]
Description=Ricky Admin Service
After=network.target

[Service]
Type=simple
WorkingDirectory=/root/2026-websites-Ricky
EnvironmentFile=/etc/ricky-admin.env
ExecStart=/usr/bin/node /root/2026-websites-Ricky/admin/server.mjs
Restart=always
RestartSec=3
User=root

[Install]
WantedBy=multi-user.target
