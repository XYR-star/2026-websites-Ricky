---
import type { CollectionEntry } from "astro:content";
import { formatDate } from "../lib/content";

interface Props {
  item: CollectionEntry<"research">;
}

const { item } = Astro.props;
---

<article class="entry fade-in">
  <div class="meta-row">
    <span>{formatDate(item.data.date)}</span>
    {item.data.project && <span class="tag">{item.data.project}</span>}
    {item.data.status && <span class="tag">{item.data.status}</span>}
  </div>
  <h3 class="entry__title">{item.data.title}</h3>
  <p>{item.data.summary}</p>
  {item.data.links.length > 0 && (
    <div class="meta-row">
      {item.data.links.map((link) => (
        <a class="section__link" href={link.href} target="_blank" rel="noreferrer">
          {link.label}
        </a>
      ))}
    </div>
  )}
</article>
