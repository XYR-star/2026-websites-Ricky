---
const links = [
  { href: "/", label: "首页" },
  { href: "/blog", label: "博客" },
  { href: "/research", label: "科研进展" },
  { href: "/travel", label: "游记" },
  { href: "/archive", label: "归档" },
  { href: "/search", label: "搜索" },
  { href: "/about", label: "关于我" },
];
---

<header class="site-header">
  <div class="shell site-header__inner">
    <a class="brand" href="/">
      <span class="brand__name">Ricky</span>
      <span class="brand__tag">Notes, Research and Travel</span>
    </a>
    <nav class="nav" aria-label="主导航">
      {links.map((link) => (
        <a href={link.href}>{link.label}</a>
      ))}
    </nav>
  </div>
</header>
