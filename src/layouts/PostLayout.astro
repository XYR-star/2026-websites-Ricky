---
import SiteLayout from "./SiteLayout.astro";
import { formatDate } from "../lib/content";

interface Props {
  title: string;
  description: string;
  date: Date;
  tags?: string[];
  cover?: string;
  eyebrow?: string;
}

const {
  title,
  description,
  date,
  tags = [],
  cover,
  eyebrow = "Essay",
} = Astro.props;
---

<SiteLayout title={`${title} · Ricky`} description={description}>
  <section class="shell page-hero">
    <div class="eyebrow">{eyebrow}</div>
    <h1>{title}</h1>
    <div class="meta-row">
      <span>{formatDate(date)}</span>
      {tags.map((tag) => (
        <span class="tag">{tag}</span>
      ))}
    </div>
    <div class="divider"></div>
  </section>
  {cover && (
    <section class="shell article-cover-wrap">
      <img class="article-cover" src={cover} alt={title} />
    </section>
  )}
  <article class="prose">
    <slot />
  </article>
</SiteLayout>
