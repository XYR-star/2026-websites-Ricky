---
import { getCollection } from "astro:content";
import PostCard from "../components/PostCard.astro";
import ResearchCard from "../components/ResearchCard.astro";
import SiteLayout from "../layouts/SiteLayout.astro";
import { siteMeta } from "../data/site";
import { getVisiblePosts, sortByDateDesc } from "../lib/content";

const posts = getVisiblePosts(await getCollection("blog")).slice(0, 3);
const research = sortByDateDesc(await getCollection("research")).slice(0, 3);
---

<SiteLayout title="Ricky · 写作与科研记录" description={siteMeta.description}>
  <section class="shell hero">
    <div>
      <div class="eyebrow">Independent Notes</div>
      <h1>写作、研究与仍在形成中的想法。</h1>
      <p>{siteMeta.intro}</p>
      <div class="hero__meta">
        <span class="pill">中文内容优先</span>
        <span class="pill">博客 / 科研进展 / 关于我</span>
        <span class="pill">持续更新中</span>
      </div>
    </div>
    <aside class="hero__panel">
      <div class="section-label">Site Focus</div>
      <dl>
        <dt>写作</dt>
        <dd>把零散观察变成可反复阅读的文章。</dd>
        <dt>研究</dt>
        <dd>记录每个阶段的推演、试验与判断。</dd>
        <dt>工作方式</dt>
        <dd>简洁发布，长期维护，避免形式先于内容。</dd>
      </dl>
    </aside>
  </section>

  <section class="shell section">
    <div class="feature-band">
      <div class="quote-block">
        <div class="section-label">Editorial Note</div>
        <blockquote>
          这个网站不是项目陈列柜，而是一份持续展开的个人工作样本。
        </blockquote>
      </div>
      <div class="note-panel">
        <div class="section-label">关于这里</div>
        <p>{siteMeta.about}</p>
        <a class="section__link" href="/about">查看更多</a>
      </div>
    </div>
  </section>

  <section class="shell section">
    <div class="section__head">
      <div>
        <div class="eyebrow">Selected Essays</div>
        <h2>最近博客</h2>
      </div>
      <a class="section__link" href="/blog">查看全部文章</a>
    </div>
    <div class="grid grid--three">
      {posts.map((post) => (
        <PostCard post={post} />
      ))}
    </div>
  </section>

  <section class="shell section">
    <div class="section__head">
      <div>
        <div class="eyebrow">Research Log</div>
        <h2>科研进展</h2>
      </div>
      <a class="section__link" href="/research">进入研究日志</a>
    </div>
    <div class="stack">
      {research.map((item) => (
        <ResearchCard item={item} />
      ))}
    </div>
  </section>
</SiteLayout>
