---
import { getCollection } from "astro:content";
import PostCard from "../components/PostCard.astro";
import ResearchCard from "../components/ResearchCard.astro";
import TravelCard from "../components/TravelCard.astro";
import SiteLayout from "../layouts/SiteLayout.astro";
import homepageData from "../data/homepage.json";
import { siteMeta } from "../data/site";
import {
  getHomepageSectionLabel,
  getOrderedHomepageSections,
  splitHomepageBody,
  type HomepageAboutNoteSection,
  type HomepageContent,
  type HomepageQuoteSection,
  type HomepageSection,
} from "../lib/homepage";
import { getVisiblePosts, getVisibleTravelPosts, sortByDateDesc } from "../lib/content";

const homepage = homepageData as HomepageContent;
const posts = getVisiblePosts(await getCollection("blog"));
const research = sortByDateDesc(await getCollection("research"));
const travel = getVisibleTravelPosts(await getCollection("travel"));
const blankLine = "\u00A0";

const orderedSections = getOrderedHomepageSections(homepage.sections);

type RenderGroup =
  | {
      kind: "featureBand";
      quote: HomepageQuoteSection;
      about: HomepageAboutNoteSection;
    }
  | {
      kind: "single";
      section: HomepageSection;
    };

const renderGroups: RenderGroup[] = [];

for (let index = 0; index < orderedSections.length; index += 1) {
  const current = orderedSections[index];
  const next = orderedSections[index + 1];

  if (current.type === "quote" && next?.type === "aboutNote") {
    renderGroups.push({
      kind: "featureBand",
      quote: current,
      about: next,
    });
    index += 1;
    continue;
  }

  renderGroups.push({
    kind: "single",
    section: current,
  });
}

---

<SiteLayout title="Ricky · 写作与科研记录" description={siteMeta.description}>
  <section class="shell hero" id={homepage.hero.id} data-home-section data-section-label="开场">
    <div class="hero__content">
      <div class:list={["eyebrow", { "copy-slot": !homepage.hero.eyebrow }]}>{homepage.hero.eyebrow || blankLine}</div>
      <h1 class:list={{ "copy-slot": !homepage.hero.title }}>{homepage.hero.title || blankLine}</h1>
      <p class:list={{ "copy-slot": !homepage.hero.intro }}>{homepage.hero.intro || blankLine}</p>
      <p class:list={["hero__note", { "copy-slot": !homepage.hero.note }]}>{homepage.hero.note || blankLine}</p>
      {(homepage.hero.primaryLinkLabel && homepage.hero.primaryLinkHref) ||
      (homepage.hero.secondaryLinkLabel && homepage.hero.secondaryLinkHref) ? (
        <div class="hero__actions">
          {homepage.hero.primaryLinkLabel && homepage.hero.primaryLinkHref && (
            <a class="hero__action hero__action--primary" href={homepage.hero.primaryLinkHref}>
              {homepage.hero.primaryLinkLabel}
            </a>
          )}
          {homepage.hero.secondaryLinkLabel && homepage.hero.secondaryLinkHref && (
            <a class="hero__action" href={homepage.hero.secondaryLinkHref}>
              {homepage.hero.secondaryLinkLabel}
            </a>
          )}
        </div>
      ) : null}
    </div>
  </section>

  {renderGroups.map((group) => {
    if (group.kind === "featureBand") {
      return (
        <section class="shell section" id={group.quote.id} data-home-section data-section-label={getHomepageSectionLabel(group.quote)}>
          <div class="feature-band">
            <div class="quote-block">
              <div class:list={["section-label", { "copy-slot": !group.quote.eyebrow }]}>{group.quote.eyebrow || blankLine}</div>
              <blockquote class:list={{ "copy-slot": !group.quote.quote }}>{group.quote.quote || blankLine}</blockquote>
            </div>
            <div class="note-panel" id={group.about.id}>
              <div class:list={["section-label", { "copy-slot": !group.about.eyebrow }]}>{group.about.eyebrow || blankLine}</div>
              <p class:list={{ "copy-slot": !group.about.body }}>{group.about.body || blankLine}</p>
              {group.about.linkLabel && group.about.linkHref && (
                <a class="section__link" href={group.about.linkHref}>
                  {group.about.linkLabel}
                </a>
              )}
            </div>
          </div>
        </section>
      );
    }

    const section = group.section;

    if (section.type === "featuredPosts") {
      return (
        <section class="shell section" id={section.id} data-home-section data-section-label={getHomepageSectionLabel(section)}>
          <div class="section__head">
            <div>
              <div class:list={["eyebrow", { "copy-slot": !section.eyebrow }]}>{section.eyebrow || blankLine}</div>
              <h2 class:list={{ "copy-slot": !section.title }}>{section.title || blankLine}</h2>
            </div>
            {section.linkLabel && section.linkHref && (
              <a class="section__link" href={section.linkHref}>
                {section.linkLabel}
              </a>
            )}
          </div>
          <div class="grid grid--three">
            {posts.slice(0, section.count ?? 3).map((post) => (
              <PostCard post={post} />
            ))}
          </div>
        </section>
      );
    }

    if (section.type === "travelList") {
      return (
        <section class="shell section" id={section.id} data-home-section data-section-label={getHomepageSectionLabel(section)}>
          <div class="section__head">
            <div>
              <div class:list={["eyebrow", { "copy-slot": !section.eyebrow }]}>{section.eyebrow || blankLine}</div>
              <h2 class:list={{ "copy-slot": !section.title }}>{section.title || blankLine}</h2>
            </div>
            {section.linkLabel && section.linkHref && (
              <a class="section__link" href={section.linkHref}>
                {section.linkLabel}
              </a>
            )}
          </div>
          <div class="grid grid--three">
            {travel.slice(0, section.count ?? 3).map((post) => (
              <TravelCard post={post} />
            ))}
          </div>
        </section>
      );
    }

    if (section.type === "researchList") {
      return (
        <section class="shell section" id={section.id} data-home-section data-section-label={getHomepageSectionLabel(section)}>
          <div class="section__head">
            <div>
              <div class:list={["eyebrow", { "copy-slot": !section.eyebrow }]}>{section.eyebrow || blankLine}</div>
              <h2 class:list={{ "copy-slot": !section.title }}>{section.title || blankLine}</h2>
            </div>
            {section.linkLabel && section.linkHref && (
              <a class="section__link" href={section.linkHref}>
                {section.linkLabel}
              </a>
            )}
          </div>
          <div class="stack">
            {research.slice(0, section.count ?? 3).map((item) => (
              <ResearchCard item={item} />
            ))}
          </div>
        </section>
      );
    }

    if (section.type === "curatedLinks") {
      return (
        <section class="shell section" id={section.id} data-home-section data-section-label={getHomepageSectionLabel(section)}>
          <div class="section__head">
            <div>
              <div class:list={["eyebrow", { "copy-slot": !section.eyebrow }]}>{section.eyebrow || blankLine}</div>
              <h2 class:list={{ "copy-slot": !section.title }}>{section.title || blankLine}</h2>
            </div>
          </div>
          <div class="curated-panel">
            {splitHomepageBody(section.body).length > 0 ? (
              splitHomepageBody(section.body).map((paragraph) => <p class="curated-panel__intro">{paragraph}</p>)
            ) : (
              <p class="curated-panel__intro copy-slot">{blankLine}</p>
            )}
            <div class="grid grid--three">
              {section.items.map((item) =>
                item.href ? (
                  <a class="card curated-card fade-in" href={item.href}>
                    <div class:list={["section-label", { "copy-slot": !item.eyebrow }]}>{item.eyebrow || blankLine}</div>
                    <h3 class:list={["card__title", { "copy-slot": !item.title }]}>{item.title || blankLine}</h3>
                    <p class:list={{ "copy-slot": !item.description }}>{item.description || blankLine}</p>
                    <span class="section__link">从这里开始</span>
                  </a>
                ) : (
                  <div class="card curated-card fade-in">
                    <div class:list={["section-label", { "copy-slot": !item.eyebrow }]}>{item.eyebrow || blankLine}</div>
                    <h3 class:list={["card__title", { "copy-slot": !item.title }]}>{item.title || blankLine}</h3>
                    <p class:list={{ "copy-slot": !item.description }}>{item.description || blankLine}</p>
                  </div>
                ),
              )}
            </div>
          </div>
        </section>
      );
    }

    if (section.type === "nowSummary") {
      return (
        <section class="shell section" id={section.id} data-home-section data-section-label={getHomepageSectionLabel(section)}>
          <div class="now-panel homepage-panel">
            <div class:list={["section-label", { "copy-slot": !section.eyebrow }]}>{section.eyebrow || blankLine}</div>
            <h2 class:list={["homepage-panel__title", { "copy-slot": !section.title }]}>{section.title || blankLine}</h2>
            <div class="stack now-panel__body">
              {splitHomepageBody(section.body).length > 0 ? (
                splitHomepageBody(section.body).map((paragraph) => <p>{paragraph}</p>)
              ) : (
                <p class="copy-slot">{blankLine}</p>
              )}
            </div>
            {section.linkLabel && section.linkHref && (
              <a class="section__link" href={section.linkHref}>
                {section.linkLabel}
              </a>
            )}
          </div>
        </section>
      );
    }

    if (section.type === "aboutNote") {
      return (
        <section class="shell section" id={section.id} data-home-section data-section-label={getHomepageSectionLabel(section)}>
          <div class="note-panel homepage-panel">
            <div class:list={["section-label", { "copy-slot": !section.eyebrow }]}>{section.eyebrow || blankLine}</div>
            <h2 class:list={["homepage-panel__title", { "copy-slot": !section.title }]}>{section.title || blankLine}</h2>
            <p class:list={{ "copy-slot": !section.body }}>{section.body || blankLine}</p>
            {section.linkLabel && section.linkHref && (
              <a class="section__link" href={section.linkHref}>
                {section.linkLabel}
              </a>
            )}
          </div>
        </section>
      );
    }

    if (section.type === "quote") {
      return (
        <section class="shell section" id={section.id} data-home-section data-section-label={getHomepageSectionLabel(section)}>
          <div class="quote-block homepage-panel">
            <div class:list={["section-label", { "copy-slot": !section.eyebrow }]}>{section.eyebrow || blankLine}</div>
            <blockquote class:list={{ "copy-slot": !section.quote }}>{section.quote || blankLine}</blockquote>
          </div>
        </section>
      );
    }

    return (
      <section class="shell section" id={section.id} data-home-section data-section-label={getHomepageSectionLabel(section)}>
        <div class="note-panel homepage-panel">
          <div>
            <div class:list={["section-label", { "copy-slot": !section.eyebrow }]}>{section.eyebrow || blankLine}</div>
            <h2 class:list={["homepage-panel__title", { "copy-slot": !section.title }]}>{section.title || blankLine}</h2>
          </div>
          {"body" in section &&
            (splitHomepageBody(section.body).length > 0 ? (
              splitHomepageBody(section.body).map((paragraph) => <p>{paragraph}</p>)
            ) : (
              <p class="copy-slot">{blankLine}</p>
            ))}
          {section.linkLabel && section.linkHref && (
            <a class="section__link" href={section.linkHref}>
              {section.linkLabel}
            </a>
          )}
        </div>
      </section>
    );
  })}
</SiteLayout>
