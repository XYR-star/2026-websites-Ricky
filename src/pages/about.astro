---
import SiteLayout from "../layouts/SiteLayout.astro";
import aboutData from "../data/about.json";

type AboutContent = {
  hero: {
    eyebrow: string;
    title: string;
    intro: string;
  };
  profileCard: {
    sectionLabel: string;
    title: string;
    body: string;
    secondaryBody?: string;
  };
  facts: {
    sectionLabel: string;
    locationLabel: string;
    location?: string;
    emailLabel: string;
    email?: string;
    topicsLabel: string;
    topics?: string;
  };
  links: Array<{
    label: string;
    href: string;
  }>;
};

const about = aboutData as AboutContent;
---

<SiteLayout title="关于我 · Ricky" description="关于站点作者、研究方向与联系方式">
  <section class="shell page-hero">
    <div class="eyebrow">{about.hero.eyebrow}</div>
    <h1>{about.hero.title}</h1>
    <p>{about.hero.intro}</p>
  </section>

  <section class="shell section">
    <div class="about-grid">
      <div class="card">
        <div class="section-label">{about.profileCard.sectionLabel}</div>
        <h2 class="card__title">{about.profileCard.title}</h2>
        <p>{about.profileCard.body}</p>
        {about.profileCard.secondaryBody && <p>{about.profileCard.secondaryBody}</p>}
      </div>
      <aside class="note-panel">
        <div class="section-label">{about.facts.sectionLabel}</div>
        <div class="about-list">
          {about.facts.location && (
            <div>
              <strong>{about.facts.locationLabel}</strong>
              <p>{about.facts.location}</p>
            </div>
          )}
          {about.facts.email && (
            <div>
              <strong>{about.facts.emailLabel}</strong>
              <p>{about.facts.email}</p>
            </div>
          )}
          {about.facts.topics && (
            <div>
              <strong>{about.facts.topicsLabel}</strong>
              <p>{about.facts.topics}</p>
            </div>
          )}
        </div>
      </aside>
    </div>
  </section>

  {about.links.length > 0 && (
    <section class="shell section">
      <div class="section__head">
        <div>
          <div class="eyebrow">Links</div>
          <h2>外部链接</h2>
        </div>
      </div>
      <div class="grid grid--three">
        {about.links.map((link) => (
          <a class="card" href={link.href} target="_blank" rel="noreferrer">
            <div class="section-label">{link.label}</div>
            <h3 class="card__title">{link.href.replace(/^mailto:/, "")}</h3>
          </a>
        ))}
      </div>
    </section>
  )}
</SiteLayout>
